---
import { getCollection, getEntry } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
  const cities = await getCollection('cities');
  return cities.map((city) => ({
    params: { slug: city.id },
    props: { city },
  }));
}

const { slug } = Astro.params;
const { city } = Astro.props;

if (!city) {
  return Astro.redirect('/404');
}

const { data } = city;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{data.title} - City Magazine</title>
    <meta name="description" content={`Discover ${data.city}, ${data.country} - ${data.region}. Explore local art, cuisine, and culture.`} />
    <meta property="og:title" content={data.title} />
    <meta property="og:description" content={`A day in ${data.city}: art, food, and culture from ${data.country}`} />
    <meta property="og:image" content={data.heroImage} />
  </head>
  <body>
    <!-- Navigation -->
    <nav style="position: fixed; top: 1rem; left: 1rem; z-index: 100;">
      <a href="/" style="display: inline-block; padding: 0.5rem 1rem; background: rgba(255,255,255,0.9); border-radius: 6px; text-decoration: none; color: var(--deep-charcoal); font-family: var(--font-label); font-size: 0.85rem; font-weight: 500; backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.5);">
        ← Back to Home
      </a>
    </nav>

    <main>
      <!-- Hero Section -->
      <div class="hero">
        <img 
          class="hero-image" 
          src={data.heroImage} 
          alt={`${data.city}, ${data.country}`}
          loading="eager"
        />
        <div class="hero-overlay">
          <h1 class="hero-title">{data.title}</h1>
        </div>
      </div>

      <!-- Main Content -->
      <div class="main-content">
        <div class="label day-in-label">A Day In {data.city}</div>
        <div class="city-writeup" set:html={data.cityWriteup.replace(/\n\n/g, '</p><p>').replace(/^/, '<p>').replace(/$/, '</p>')} />

        <!-- Art Section -->
        <section class="section">
          <h2 class="section-header">The Art</h2>
          <div class="art-section">
            <img 
              class="art-image" 
              src={data.artwork.imageUrl} 
              alt={`${data.artwork.title} by ${data.artwork.artist}`}
              loading="lazy"
            />
            <div class="art-content">
              <h3>{data.artwork.title}</h3>
              <div class="art-artist">{data.artwork.artist}</div>
              <div set:html={data.artwork.writeup.replace(/\n\n/g, '</p><p>').replace(/^/, '<p>').replace(/$/, '</p>')} />
            </div>
          </div>
        </section>

        <!-- Food Section -->
        <section class="section">
          <h2 class="section-header">The Flavor</h2>
          <div class="food-section">
            <div class="food-content">
              <h3 class="food-name">{data.food.name}</h3>
              <div set:html={data.food.writeup.replace(/\n\n/g, '</p><p>').replace(/^/, '<p>').replace(/$/, '</p>')} />
            </div>
            <img 
              class="food-image" 
              src={data.food.imageUrl} 
              alt={data.food.name}
              loading="lazy"
            />
          </div>
        </section>

        <!-- Song Section -->
        <section class="section">
          <div class="song-section">
            <h2 class="section-header">The Sound</h2>
            <h3 class="song-title">{data.song.title}</h3>
            <div class="song-artist">{data.song.artist}</div>
            <a href={data.song.youtubeUrl} target="_blank" rel="noopener noreferrer" class="youtube-link">
              Listen on YouTube
            </a>
          </div>
        </section>

        <!-- Footer -->
        <footer class="footer">
          A new city, every morning.
        </footer>
      </div>
    </main>

    <script>
      // Add loaded class for lazy images when they load
      document.querySelectorAll('img[loading="lazy"]').forEach(img => {
        if (img.complete) {
          img.classList.add('loaded');
        } else {
          img.addEventListener('load', () => {
            img.classList.add('loaded');
          });
        }
      });

      // Smooth scroll for navigation
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            target.scrollIntoView({
              behavior: 'smooth'
            });
          }
        });
      });
    </script>
  </body>
</html>